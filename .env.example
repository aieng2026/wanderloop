# AI Gateway — production deployments use the Vercel OIDC token automatically.
# For local dev, run `vercel env pull .env.local` to get an AI_GATEWAY_API_KEY
# (and a VERCEL_OIDC_TOKEN that the SDK can fall back on).
# AI_GATEWAY_API_KEY=

# Admin login (pre-configured single user; no public signup)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# HMAC secret for signing session cookies. Generate with:
#   openssl rand -hex 32
AUTH_SECRET=

# Cron secret — protects /api/cron/* endpoints
# CRON_SECRET=

# Vercel Blob — auto-populated when Blob is enabled on the project
# BLOB_READ_WRITE_TOKEN=
