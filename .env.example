# Anthropic API key — required for the AI agent
ANTHROPIC_API_KEY=

# Optional — for AI Gateway routing (when enabled in the Vercel dashboard)
# AI_GATEWAY_API_KEY=

# Cron secret — protects /api/cron/* endpoints
# CRON_SECRET=

# Vercel Blob — auto-populated when Blob is enabled on the project
# BLOB_READ_WRITE_TOKEN=
